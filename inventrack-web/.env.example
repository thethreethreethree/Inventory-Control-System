# Postgres connection string.
# Local dev: a local Postgres. Production: Neon or Vercel Postgres (use the
# POOLED connection string for serverless).
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Secret used to sign session tokens. Generate a long random value in production,
# e.g.  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="change-me-to-a-long-random-string"
